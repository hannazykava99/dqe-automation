pipeline {
    agent any

    environment {
        POSTGRES_SECRET = credentials('jenkins-postgres-credentials')
        REPO_URL = 'https://github.com/hannazykava99/dqe-automation.git'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Clone Repo') {
            steps {
                sh """
                echo "Cloning repository..."
                git clone ${REPO_URL}
                ls -R dqe-automation
                """
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("dqe-automation/PyTest DQ Framework") {
                    sh """
                    echo "Installing dependencies..."
                    python3 -m pip install --break-system-packages --upgrade pip
                    pip install --break-system-packages setuptools wheel
                    pip install --break-system-packages -r requirements.txt
                    """
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir("dqe-automation/PyTest DQ Framework") {
                    sh """
                    echo "Running tests..."
                    pytest tests \
                        --db_host=host.containers.internal \
                        --db_port=5434 \
                        --db_name=mydatabase \
                        --db_user=$POSTGRES_SECRET_USR \
                        --db_password=$POSTGRES_SECRET_PSW \
                        --html=html_report/report.html \
                        --self-contained-html
                    """
                }
            }
        }
    }

    post {
        always {
            dir("dqe-automation/PyTest DQ Framework") {
                archiveArtifacts artifacts: 'html_report/**', allowEmptyArchive: true

                publishHTML(target: [
                    allowMissing: true,
                    keepAll: true,
                    reportDir: 'html_report',
                    reportFiles: 'report.html',
                    reportName: 'HTML Test Report'
                ])
            }
        }
    }
}
