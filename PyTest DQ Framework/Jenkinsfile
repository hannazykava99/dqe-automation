pipeline {

    agent any

    environment {
        // Postgres credentials stored in Jenkins Credentials Manager
        POSTGRES_SECRET = credentials('jenkins-postgres-credentials')

        // GitHub repository URL
        REPO_URL = 'https://github.com/hannazykava99/dqe-automation.git'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                // Remove everything from workspace to ensure a clean environment
                deleteDir()
            }
        }

        stage('Clone Repo') {
            steps {
                sh '''
                echo "Cloning repository into workspace root..."

                # Clone repository directly into workspace root directory
                git clone ${REPO_URL} .

                echo "Workspace content after clone:"
                ls -la
                '''
            }
        }

        stage('Prepare Parquet Data') {
            steps {
                dir("PyTest DQ Framework") {
                    sh '''
                    echo "Preparing parquet data for test execution..."

                    # Remove old parquet data if it exists
                    rm -rf parquet_data

                    # Copy fresh parquet data from container root (/parquet_data)
                    # into the project directory so tests can access it
                    cp -r /parquet_data .

                    echo "Verifying parquet_data structure:"
                    ls parquet_data
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("PyTest DQ Framework") {
                    sh '''
                    echo "Installing project dependencies..."

                    # Install basic Python packaging tools
                    python3 -m pip install --break-system-packages setuptools wheel

                    # Install all required project dependencies
                    pip install --break-system-packages -r requirements.txt
                    '''
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir("PyTest DQ Framework") {
                    sh '''
                    echo "Executing pytest test suite..."

                    # Run data quality tests with database connection parameters
                    pytest tests \
                        --db_host=host.containers.internal \
                        --db_port=5434 \
                        --db_name=mydatabase \
                        --db_user=$POSTGRES_SECRET_USR \
                        --db_password=$POSTGRES_SECRET_PSW \
                        --html=html_report/report.html \
                        --self-contained-html
                    '''
                }
            }
        }
    }

    post {

        always {
            dir("PyTest DQ Framework") {

                // Archive HTML report as Jenkins build artifact
                archiveArtifacts artifacts: 'html_report/**', allowEmptyArchive: true

                // Publish HTML report in Jenkins UI for easy viewing
                publishHTML(target: [
                    allowMissing: true,
                    keepAll: true,
                    reportDir: 'html_report',
                    reportFiles: 'report.html',
                    reportName: 'HTML Test Report'
                ])
            }
        }
    }
}
